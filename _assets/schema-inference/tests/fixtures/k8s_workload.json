{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Kubernetes-like Workload",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "enum": ["apps/v1", "batch/v1"] },
    "kind": { "enum": ["Deployment", "StatefulSet", "Job", "CronJob"] },
    "metadata": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z][a-z0-9-]{0,62}$" },
        "namespace": { "type": "string", "pattern": "^[a-z][a-z0-9-]{0,62}$" },
        "labels": {
          "type": "object",
          "additionalProperties": { "type": "string", "maxLength": 63 }
        }
      },
      "additionalProperties": false
    },
    "spec": {
      "type": "object",
      "properties": {
        "replicas": { "type": "integer", "minimum": 0, "maximum": 10 },
        "strategy": {
          "type": "object",
          "required": ["type"],
          "properties": {
            "type": { "enum": ["Recreate", "RollingUpdate"] },
            "maxSurge": { "type": "integer", "minimum": 0, "maximum": 5 },
            "maxUnavailable": { "type": "integer", "minimum": 0, "maximum": 5 }
          },
          "additionalProperties": false
        },
        "containers": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "items": {
            "type": "object",
            "required": ["name", "image"],
            "properties": {
              "name": { "type": "string", "pattern": "^[a-z][a-z0-9-]{0,30}$" },
              "image": { "type": "string", "pattern": "^[a-z][a-z0-9/.:-]{0,100}$" },
              "ports": {
                "type": "array",
                "maxItems": 3,
                "items": {
                  "type": "object",
                  "required": ["containerPort", "protocol"],
                  "properties": {
                    "containerPort": { "type": "integer", "minimum": 1, "maximum": 65535 },
                    "protocol": { "enum": ["TCP", "UDP", "SCTP"] }
                  },
                  "additionalProperties": false
                }
              },
              "env": {
                "type": "array",
                "maxItems": 5,
                "items": {
                  "type": "object",
                  "required": ["name"],
                  "properties": {
                    "name": { "type": "string", "pattern": "^[A-Z_]{1,30}$" },
                    "value": { "type": "string", "maxLength": 100 },
                    "valueFrom": {
                      "type": "object",
                      "properties": {
                        "source": { "enum": ["configMap", "secret", "fieldRef"] }
                      },
                      "additionalProperties": false
                    }
                  },
                  "additionalProperties": false
                }
              },
              "resources": {
                "type": "object",
                "properties": {
                  "limits": {
                    "type": "object",
                    "properties": {
                      "cpu": { "type": "string", "pattern": "^[0-9]+m?$" },
                      "memory": { "type": "string", "pattern": "^[0-9]+(Mi|Gi)$" }
                    },
                    "additionalProperties": false
                  }
                },
                "additionalProperties": false
              },
              "restartPolicy": { "enum": ["Always", "OnFailure", "Never"] }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
