{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Messaging System Event",
  "oneOf": [
    {
      "type": "object",
      "required": ["kind", "channel", "payload"],
      "properties": {
        "kind": { "const": "message" },
        "channel": { "enum": ["email", "sms", "push", "webhook"] },
        "priority": { "enum": ["low", "normal", "high", "critical"] },
        "payload": {
          "type": "object",
          "required": ["format"],
          "properties": {
            "format": { "enum": ["text", "html", "markdown"] },
            "body": { "type": "string", "maxLength": 500 },
            "subject": { "type": "string", "maxLength": 100 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    {
      "type": "object",
      "required": ["kind", "status"],
      "properties": {
        "kind": { "const": "delivery" },
        "status": { "enum": ["pending", "sent", "delivered", "bounced", "failed"] },
        "channel": { "enum": ["email", "sms", "push", "webhook"] },
        "attempt": { "type": "integer", "minimum": 1, "maximum": 5 }
      },
      "additionalProperties": false
    },
    {
      "type": "object",
      "required": ["kind", "operation"],
      "properties": {
        "kind": { "const": "subscription" },
        "operation": { "enum": ["subscribe", "unsubscribe", "update"] },
        "channel": { "enum": ["email", "sms", "push", "webhook"] },
        "preferences": {
          "type": "object",
          "properties": {
            "frequency": { "enum": ["immediate", "daily", "weekly"] }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  ],
  "discriminator": { "propertyName": "kind" }
}
