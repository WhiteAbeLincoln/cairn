{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Pet Store Event",
  "oneOf": [
    {
      "type": "object",
      "required": ["type", "species", "name"],
      "properties": {
        "type": { "const": "animal" },
        "species": { "enum": ["dog", "cat", "bird", "fish", "hamster"] },
        "name": { "type": "string", "maxLength": 50 },
        "age": { "type": "integer", "minimum": 0, "maximum": 30 },
        "status": { "enum": ["available", "adopted", "hold"] },
        "tags": {
          "type": "array",
          "items": { "type": "string", "maxLength": 20 }
        }
      },
      "additionalProperties": false
    },
    {
      "type": "object",
      "required": ["type", "action"],
      "properties": {
        "type": { "const": "event" },
        "action": { "enum": ["created", "updated", "deleted", "transferred"] },
        "target_id": { "type": "string", "pattern": "^[a-f0-9]{8}$" },
        "actor": {
          "type": "object",
          "required": ["role"],
          "properties": {
            "role": { "enum": ["admin", "staff", "volunteer"] },
            "name": { "type": "string", "maxLength": 50 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    {
      "type": "object",
      "required": ["type", "level", "message"],
      "properties": {
        "type": { "const": "log" },
        "level": { "enum": ["debug", "info", "warn", "error"] },
        "message": { "type": "string", "maxLength": 200 },
        "category": { "enum": ["auth", "inventory", "billing"] }
      },
      "additionalProperties": false
    }
  ],
  "discriminator": { "propertyName": "type" }
}
