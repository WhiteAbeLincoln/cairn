package cairn:daemon@0.1.0;

interface types {
    type session-id = string;     // UUIDv7
    type client-id = string;

    record http-route {
        methods: list<string>,
        host: option<string>,
        path-prefix: option<string>,
    }

    record http-proxy-spec {
        routes: list<http-route>,
    }

    record session-spec {
        name: option<string>,
        command: list<string>,
        env: list<tuple<string, string>>,
        env-inherit: bool,
        workdir: option<string>,
        tty: bool,
        stdin: bool,
        idle-timeout-secs: option<u64>,
        scrollback-lines: u32,
        http-proxy: option<http-proxy-spec>,
    }

    record session-info {
        id: session-id,
        name: option<string>,
        pid: option<u32>,
        cols: u16,
        rows: u16,
        attached-clients: list<client-id>,
        created-at-unix-ms: u64,
        exit: option<exit-status>,
        spec: session-spec,
    }

    record exit-status {
        code: option<s32>,
        signal: option<u8>,
        unix-ms: u64,
        reason: option<string>,
    }

    variant signal {
        named(signal-name),
        numbered(u8),
    }

    enum signal-name {
        hup, int, quit, ill, trap, abrt, bus, fpe, kill,
        usr1, segv, usr2, pipe, alrm, term, chld, cont,
        stop, tstp, ttin, ttou, urg, xcpu, xfsz, vtalrm,
        prof, winch, io, sys,
    }

    variant log-window {
        tail(u32),
        all,
    }

    record attach-init {
        cols: u16,
        rows: u16,
        no-stdin: bool,
    }

    variant client-event {
        input(list<u8>),
        resize(tuple<u16, u16>),
        detach,
    }

    variant server-event {
        snapshot(list<u8>),
        output(list<u8>),
        exited(exit-status),
        error(error),
    }

    // Case ORDER is the wire format: snapshot, upsert, removed.
    variant session-event {
        snapshot(list<session-info>),
        upsert(session-info),
        removed(session-id),
    }

    record call-context {
        trace-context: option<string>,
    }

    record error {
        code: string,
        message: string,
    }
}

interface http-proxy {
    use types.{session-id, error, call-context};

    type exchange-id = u64;
    type header = tuple<string, list<u8>>;

    record request-head {
        method: string,
        uri: string,
        version: string,
        headers: list<header>,
    }

    record response-head {
        status: u16,
        version: string,
        headers: list<header>,
    }

    record intercepted-request {
        id: exchange-id,
        head: request-head,
        body: list<u8>,
    }

    record response-start {
        id: exchange-id,
        head: response-head,
    }

    record body-chunk {
        id: exchange-id,
        bytes: list<u8>,
    }

    variant interceptor-action {
        forward(exchange-id),
        response-start(response-start),
        response-body(body-chunk),
        response-end(exchange-id),
        fail(tuple<exchange-id, error>),
    }

    variant interceptor-event {
        request(intercepted-request),
        cancelled(exchange-id),
        error(error),
    }

    record observed-body {
        bytes: list<u8>,
        total-bytes: u64,
        truncated: bool,
        complete: bool,
    }

    record observed-exchange {
        id: exchange-id,
        request: request-head,
        request-body: observed-body,
        response: option<response-head>,
        response-body: observed-body,
        started-at-unix-ms: u64,
        completed-at-unix-ms: option<u64>,
        failure: option<error>,
    }

    record request-started {
        id: exchange-id,
        head: request-head,
        unix-ms: u64,
    }

    record body-ended {
        id: exchange-id,
        total-bytes: u64,
        truncated: bool,
    }

    record response-started {
        id: exchange-id,
        head: response-head,
    }

    record exchange-failed {
        id: exchange-id,
        error: error,
    }

    variant observation-event {
        snapshot(list<observed-exchange>),
        request-start(request-started),
        request-body(body-chunk),
        request-end(body-ended),
        response-start(response-started),
        response-body(body-chunk),
        response-end(body-ended),
        completed(tuple<exchange-id, u64>),
        failed(exchange-failed),
        error(error),
    }

    intercept: func(ctx: option<call-context>, id: session-id,
                    actions: stream<interceptor-action>) -> stream<interceptor-event>;

    watch: func(ctx: option<call-context>, id: session-id) -> stream<observation-event>;
}

interface sessions {
    use types.{
        session-id, client-id, session-spec, session-info, signal,
        log-window, attach-init, client-event, server-event, session-event,
        exit-status, error, call-context,
    };

    list-all: func(ctx: option<call-context>) -> list<session-info>;
    inspect:  func(ctx: option<call-context>, id: session-id) -> result<session-info, error>;

    watch-sessions: func(ctx: option<call-context>) -> stream<session-event>;

    create:  func(ctx: option<call-context>, spec: session-spec) -> result<session-info, error>;
    rename:  func(ctx: option<call-context>, id: session-id, new-name: string) -> result<_, error>;
    restart: func(ctx: option<call-context>, id: session-id, force: bool) -> result<_, error>;
    kill:    func(ctx: option<call-context>, id: session-id, sig: signal, grace-ms: option<u32>) -> result<_, error>;
    kick:    func(ctx: option<call-context>, id: session-id, client: option<client-id>) -> result<_, error>;

    wait:    func(ctx: option<call-context>, id: session-id) -> future<exit-status>;

    logs:    func(ctx: option<call-context>, id: session-id, window: log-window, follow: bool)
             -> stream<list<u8>>;

    attach:  func(ctx: option<call-context>, id: session-id, init: attach-init,
                  events: stream<client-event>) -> stream<server-event>;

    send:    func(ctx: option<call-context>, id: session-id, chunks: stream<list<u8>>)
             -> result<_, error>;
}

interface meta {
    use types.{error, call-context};

    record version-info {
        daemon: string,
        protocol: string,    // "cairn:daemon@0.1.0"
    }

    authenticate: func(ctx: option<call-context>, token: string) -> result<_, error>;

    whoami:  func(ctx: option<call-context>) -> result<string, error>;
    version: func(ctx: option<call-context>) -> version-info;
}

world daemon {
    export sessions;
    export meta;
    export http-proxy;
}

// Client world used for testing and CLI integration.
// Importing the interfaces generates free client-invocation functions
// at `bindings::cairn::daemon::{sessions,meta}::*`.
world daemon-client {
    import sessions;
    import meta;
    import http-proxy;
}
